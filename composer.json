{
    "name": "sultans-smoke/ecommerce",
    "description": "Sultan's Smoke - Premium Tobacco, Vape & Shisha Store",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "phpmailer/phpmailer": "^6.8",
        "firebase/php-jwt": "^7.0",
        "vlucas/phpdotenv": "^5.6",
        "laminas/laminas-escaper": "^2.13",
        "laminas/laminas-filter": "^2.35",
        "defuse/php-encryption": "^2.4",
        "bugsnag/bugsnag": "^3.30"
    },
    "autoload": {
        "psr-4": {
            "App\\Core\\": "app/core/",
            "App\\Controllers\\": "app/controllers/",
            "App\\Models\\": "app/models/",
            "App\\Middleware\\": "app/middleware/",
            "App\\Gateways\\": "app/gateways/"
        },
        "files": [
            "app/helpers/functions.php",
            "app/helpers/validators.php",
            "app/helpers/formatters.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "policy": {
            "advisories": {
                "block": false
            }
        },
        "allow-plugins": {
            "infection/extension-installer": true
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10",
        "phpstan/phpstan": "^1",
        "infection/infection": "^0.28"
    }
}
