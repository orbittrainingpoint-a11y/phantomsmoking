{
    "name": "sultans-smoke/ecommerce",
    "description": "Sultan's Smoke - Premium Tobacco, Vape & Shisha Store",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "phpmailer/phpmailer": "^6.8",
        "firebase/php-jwt": "^6.9",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/helpers/functions.php",
            "app/helpers/validators.php",
            "app/helpers/formatters.php"
        ]
    },
    "config": {
        "optimize-autoloader": true
    }
}
