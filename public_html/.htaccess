Options -Indexes
Options -MultiViews

# ── Hostinger Nginx+Apache: allow all methods ──────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Tell Nginx/Apache to accept all HTTP methods
    RewriteCond %{REQUEST_METHOD} ^(GET|POST|PUT|DELETE|PATCH|OPTIONS|HEAD)$
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Handle OPTIONS preflight (CORS)
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^(.*)$ index.php [QSA,L]

    # Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP:X-Forwarded-Proto} !https
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Block access to sensitive files
    RewriteRule ^\.env$                  - [F,L]
    RewriteRule ^composer\.(json|lock)$  - [F,L]
    RewriteRule ^\.git                   - [F,L]
    RewriteRule ^vendor/                 - [F,L]
    RewriteRule ^logs/                   - [F,L]
    RewriteRule ^scripts/                - [F,L]
    RewriteRule \.(sql|log|sh|bak)$      - [F,L]
    RewriteRule ^reset_admin\.php$       - [F,L]

    # Serve real files/dirs directly
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Route everything else to index.php — ALL methods
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# ── Allow all HTTP methods (required for Hostinger) ─────────────────
<LimitExcept GET POST PUT DELETE PATCH OPTIONS HEAD>
    Order allow,deny
    Allow from all
</LimitExcept>

# ── Increase upload/post limits for product forms ───────────────────
<IfModule mod_php.c>
    php_value upload_max_filesize 32M
    php_value post_max_size       64M
    php_value max_input_vars      5000
    php_value max_execution_time  120
    php_value memory_limit        256M
</IfModule>

# ── Gzip compression ────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# ── Browser caching for assets ──────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg              "access plus 1 year"
    ExpiresByType image/png               "access plus 1 year"
    ExpiresByType image/webp              "access plus 1 year"
    ExpiresByType text/css                "access plus 1 month"
    ExpiresByType application/javascript  "access plus 1 month"
</IfModule>

# ── Security headers ────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
