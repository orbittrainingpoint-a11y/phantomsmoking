Options -Indexes
Options -MultiViews

# ─── Block PHP execution in upload/asset dirs at root level ──────────────────
# Extra layer: assets and uploads should never execute PHP regardless of sub-.htaccess
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Deny PHP files inside assets/ or uploads/ — shell upload protection
    RewriteRule ^(assets|uploads)/.*\.ph(p[2-9]?|tml|ar)$ - [F,L]
</IfModule>

# ─── Strip information-disclosure headers ────────────────────────────────────
<IfModule mod_headers.c>
    Header unset X-Powered-By
    Header always unset X-Powered-By
    # ServerTokens Prod must be set in httpd.conf; this hides the PHP suffix
    Header always set Server "Apache"
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Handle OPTIONS preflight
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^(.*)$ index.php [QSA,L]

    # Force HTTPS — Hostinger uses X-Forwarded-Proto
    RewriteCond %{HTTP:X-Forwarded-Proto} =http
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Block sensitive files
    RewriteRule ^\.env$                 - [F,L]
    RewriteRule ^composer\.(json|lock)$ - [F,L]
    RewriteRule ^\.git                  - [F,L]
    RewriteRule ^vendor/                - [F,L]
    RewriteRule ^logs/                  - [F,L]
    RewriteRule ^scripts/               - [F,L]
    RewriteRule \.(sql|log|sh|bak)$     - [F,L]
    RewriteRule ^reset_admin\.php$      - [F,L]
    RewriteRule ^test_smtp\.php$        - [F,L]
    RewriteRule ^add_phantom_admin\.php$ - [F,L]
    RewriteRule ^migrate_features\.php$ - [F,L]

    # Serve real files and directories directly
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route everything else to index.php
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg             "access plus 1 year"
    ExpiresByType image/png              "access plus 1 year"
    ExpiresByType image/webp             "access plus 1 year"
    ExpiresByType text/css               "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>
