APP_NAME="Sultan's Smoke"
APP_URL=http://yourdomain.com
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Asia/Dubai
APP_KEY=your_32_char_random_key_here

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sultans_smoke_db
DB_USER=your_db_user
DB_PASS=your_db_password
DB_CHARSET=utf8mb4

MAIL_DRIVER=smtp
MAIL_HOST=your_smtp_host
MAIL_PORT=587
MAIL_USERNAME=your_smtp_user
MAIL_PASSWORD=your_smtp_password
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="Sultan's Smoke"

SMS_DRIVER=unifonic
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=SultansSmoke

TELR_STORE_ID=your_telr_store_id
TELR_AUTH_KEY=your_telr_auth_key
TELR_TEST_MODE=false

GOOGLE_MAPS_API_KEY=your_google_maps_key

SESSION_LIFETIME=7200
SESSION_SECURE=true
SESSION_HTTPONLY=true

UPLOAD_MAX_SIZE=5242880
UPLOAD_PATH=/uploads/
